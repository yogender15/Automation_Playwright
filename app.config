<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <appSettings>
    <!-- Environment URLs -->
    <add key="SITBaseUrl"           value="" />
    <add key="UATBaseUrl"           value="" />
    <add key="PPEBaseUrl"           value="" />
    <add key="LAPortalBaseUrl"      value="" />

    <!-- Active environment -->
    <add key="EnvironmentVal"       value="SITBaseUrl" />
    <add key="EnvironmentValFilePath" value="..\..\Properties\environment.properties" />

    <!-- Browser -->
