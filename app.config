    <!-- Credentials -->
    <add key="Username"             value="" />
    <add key="Password"             value="" />
    <add key="LAPortalUsername"     value="" />
    <add key="LAPortalPassword"     value="" />

    <!-- Test data -->
    <add key="TestDataExcelFilePath" value="" />
    <add key="TestOutPutExcelPath"   value="" />

    <!-- DB / API -->
    <add key="SQLQueryPropertiesFilePath" value="" />
    <add key="BaseApiUrl"           value="" />
    <add key="SearchJobRelativeUrl" value="" />
    <add key="ReqClientId"          value="" />
    <add key="OrgId"                value="" />
    <add key="CrmOwinAuth"          value="" />

    <!-- Misc -->
